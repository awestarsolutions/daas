RewriteEngine On

# Root URL -> landing page
RewriteRule ^$ public/index.php [L]

# Clean API endpoint
RewriteRule ^delay$ public/delay.php [L]
RewriteRule ^docs$ public/docs.php [L]


# If the file or directory exists, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, route everything to /public
RewriteRule ^(.*)$ public/$1 [L]
